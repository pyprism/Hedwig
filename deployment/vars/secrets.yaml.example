# Example secrets file — copy to secrets.yaml and fill in your values:
#   cp vars/secrets.yaml.example vars/secrets.yaml
# IMPORTANT: secrets.yaml is gitignored — NEVER commit real secrets to git!

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================
# Base directory where the application is deployed
deployment_base_dir: "/opt/hedwig"

# Deployment user (created on the server if it doesn't exist)
deployment_user: "hedwig"

# =============================================================================
# GIT/SSH SETTINGS (only needed for a PRIVATE fork)
# =============================================================================
# Hedwig is public, so HTTPS cloning works out of the box and you can leave
# this section commented out. For a private fork, generate a deploy key:
#   ssh-keygen -t rsa -b 4096 -C "deploy@hedwig" -f deploy_key
# add deploy_key.pub as a deploy key in the repo settings, set project_repo in
# group_vars/all.yaml to the SSH URL, and paste the private key below.
#git_ssh_private_key: ""
#git_ssh_public_key: ""

# =============================================================================
# DJANGO SETTINGS
# =============================================================================
django_secret_key: "change-me-generate-a-long-random-string"
django_debug: false
django_allowed_hosts: ["yourdomain.com", "127.0.0.1", "localhost"]
# Only used when debug=false: HSTS max-age in seconds
secure_hsts_seconds: 31536000

# =============================================================================
# DATABASE SETTINGS (PostgreSQL — runs on the host, reached via host-gateway)
# =============================================================================
db_name: hedwig
db_user: hedwig
db_password: "change-me"
db_host: host-gateway  # "localhost" if DB is on the same host outside Docker, or IP/hostname if remote
db_port: 5432

# =============================================================================
# DOCKER SETTINGS
# =============================================================================
# Host port mapped to the container's port 8000 (bound to 127.0.0.1 — front with nginx/caddy)
server_port: 8001

# =============================================================================
# SENTRY (optional — leave dsn empty to disable)
# =============================================================================
sentry_dsn: ""
# Fraction of requests/tasks traced (0.0-1.0). Only applies when debug=false; keep low in prod.
sentry_traces_sample_rate: 0.0

# =============================================================================
# AWS S3 / S3-COMPATIBLE STORAGE (attachments)
# =============================================================================
aws_access_key_id: ""
aws_secret_access_key: ""
aws_storage_bucket_name: hedwig
aws_s3_region_name: us-east-1
aws_s3_custom_domain: ""
aws_s3_endpoint_url: ""

# =============================================================================
# RABBITMQ (Celery broker)
# =============================================================================
# Format: amqp://<user>:<password>@<host>:<port>/<vhost>
# Use host.docker.internal so containers reach RabbitMQ on the host.
rabbitmq_url: "amqp://guest:guest@host.docker.internal:5672/hedwig"

# =============================================================================
# JWT TOKEN LIFETIMES
# =============================================================================
jwt_access_minutes: 60
jwt_refresh_days: 30

# =============================================================================
# MISC
# =============================================================================
# First registered user becomes staff/superuser; close after bootstrap.
registration_open: false
time_zone: "Asia/Dhaka"

# Celery beat job tuning (optional — defaults applied in env.j2 if omitted)
provider_health_check_interval_minutes: 15
webhook_log_retry_stale_minutes: 30
webhook_log_max_attempts: 10
daily_send_log_retention_days: 90
