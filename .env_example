# Environment configuration for Hedwig
# Copy to .env and fill in your values: cp .env.example .env
# IMPORTANT: Never commit .env to git!

# Django Core Settings
secret_key=your-secret-key-here-change-this
debug=false
allowed_hosts=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1
# Only used when debug=false: max-age for the Strict-Transport-Security header.
secure_hsts_seconds=31536000

# Database Configuration
db_name=hedwig
db_user=hedwig
db_password=your-database-password
db_host=localhost
db_port=5432

# Docker Compose Settings
# Port on the host that maps to container port 8000
server_port=8001

# Sentry (optional - leave empty if not using)
sentry_dsn=
# Fraction of requests/tasks traced for performance monitoring (0.0-1.0). Only
# applies when debug=false; keep this low in prod, 1.0 is expensive.
sentry_traces_sample_rate=0.0

# AWS S3 Configuration
aws_access_key_id=your-aws-access-key-id
aws_secret_access_key=your-aws-secret-access-key
aws_storage_bucket_name=your-s3-bucket-name
aws_s3_region_name=your-s3-region-name
aws_s3_custom_domain=your-s3-custom-domain
aws_s3_endpoint_url=your-s3-endpoint-url

# RabbitMQ (Celery broker)
# Format: amqp://<user>:<password>@<host>:<port>/<vhost>
rabbitmq_url=amqp://guest:guest@localhost:5672/hedwig/  # create a vhost(ex hedwig) manually if needed

# JWT token lifetimes
jwt_access_minutes=60
jwt_refresh_days=30

# Self-service registration (POST /api/accounts/users/register/). The first
# registered user becomes staff/superuser. Defaults to closed when debug=false;
# see hiren/settings.py for the prod bootstrap flow.
registration_open=true
time_zone=Asia/Dhaka

# Celery beat job tuning
# How often to run provider health checks (EmailProvider.last_health_check_at/error).
provider_health_check_interval_minutes=15
# A pending/processing webhook log older than this is considered stuck and retried.
webhook_log_retry_stale_minutes=30
# Stop retrying a webhook log after this many attempts.
webhook_log_max_attempts=10
# How many days of DailyDomainSendLog rows to keep before the cleanup task deletes them.
daily_send_log_retention_days=90
